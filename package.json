{
  "name": "pipeline.js",
  "description": "Pipeline.js - async workflow framework for node.js and browser",
  "version": "2.0.31",
  "author": {
    "name": "Alex Vedmedenko",
    "email": "vedmalex@gmail.com"
  },
  "keywords": [
    "workflow",
    "async",
    "pipeline"
  ],
  "dependencies": {
    "ajv": "^8.17.1",
    "ajv-errors": "^3.0.0",
    "ajv-formats": "^3.0.1",
    "ajv-keywords": "^5.1.0",
    "fte.js": "3.0.0-rc.4",
    "js-schema": "1.0.1",
    "lodash": "^4.17.21",
    "semver": "^7.7.1"
  },
  "devDependencies": {
    "glob": "^8.0.3",
    "@types/bun": "^1.2.5",
    "@types/lodash": "^4.17.16",
    "@types/node": "22.13.10",
    "esbuild": "^0.25.1",
    "typescript": "next"
  },
  "main": "lib/index.js",
  "types": "lib/index.d.ts",
  "files": [
    "lib",
    "src"
  ],
  "scripts": {
    "prepublish": "npm run clean && npm run lib",
    "build": "bun build.ts && tsc -p tsconfig.bun.json",
    "lib": "tsc -p tsconfig.json",
    "watch": "tsc -w -p tsconfig.json",
    "clean": "git clean -dfqX -- {types,dist}/** && rm -rf tsconfig.tsbuildinfo dist types"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vedmalex/pipeline.js.git"
  },
  "readmeFilename": "README.md",
  "bugs": {
    "url": "https://github.com/vedmalex/pipeline.js/issues"
  },
  "homepage": "https://github.com/vedmalex/pipeline.js"
}
