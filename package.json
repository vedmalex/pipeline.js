{
  "name": "pipeline.js",
  "description": "Pipeline.js - async workflow framework for node.js and browser",
  "version": "2.0.28",
  "author": {
    "name": "Alex Vedmedenko",
    "email": "vedmalex@gmail.com"
  },
  "keywords": [
    "workflow",
    "async",
    "pipeline"
  ],
  "dependencies": {
    "ajv": "^8.11.2",
    "ajv-errors": "^3.0.0",
    "ajv-formats": "^2.1.1",
    "ajv-keywords": "^5.1.0",
    "colors": "1.4.0",
    "debug": "4.3.4",
    "fte.js": "3.0.0-rc.4",
    "js-schema": "1.0.1",
    "lodash": "^4.17.21",
    "semver": "7.3.8",
    "zod": "^3.19.1"
  },
  "devDependencies": {
    "@types/bun": "^1.2.1",
    "@types/lodash": "^4.14.189",
    "@types/node": "18.11.9",
    "@typescript-eslint/eslint-plugin": "5.44.0",
    "@typescript-eslint/parser": "5.44.0",
    "benchmark": "2.1.4",
    "browserify": "17.0.0",
    "dox": "1.0.0",
    "doxx": "2.1.1",
    "esbuild": "^0.24.2",
    "prettier": "^2.8.0",
    "typescript": "next"
  },
  "main": "lib/index.js",
  "types": "lib/index.d.ts",
  "files": [
    "lib",
    "src"
  ],
  "scripts": {
    "prepublish": "npm run clean && npm run lib",
    "build": "bun build.ts && tsc -p tsconfig.bun.json",
    "lib": "tsc -p tsconfig.json",
    "watch": "tsc -w -p tsconfig.json",
    "clean": "git clean -dfqX -- {types,dist}/** && rm -rf tsconfig.tsbuildinfo dist types"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vedmalex/pipeline.js.git"
  },
  "readmeFilename": "README.md",
  "bugs": {
    "url": "https://github.com/vedmalex/pipeline.js/issues"
  },
  "homepage": "https://github.com/vedmalex/pipeline.js"
}